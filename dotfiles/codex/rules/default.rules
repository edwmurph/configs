# Conservative starter rules for Codex command approvals.
# Auto-allow read-only git/GitHub inspection, keep risky operations gated.

prefix_rule(
    pattern = ["git", ["status", "diff", "show", "log", "branch", "rev-parse", "ls-files"]],
    decision = "allow",
    justification = "Read-only git inspection commands are safe to run without approval",
    match = [
        "git status",
        "git diff --name-only",
        "git show HEAD~1",
        "git log --oneline -n 20",
        "git branch --show-current",
        "git rev-parse --show-toplevel",
        "git ls-files",
    ],
    not_match = [
        "git add .",
        "git commit -m update",
        "git push",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", ["view", "checks", "diff", "list", "status"]],
    decision = "allow",
    justification = "Read-only PR inspection commands are safe to run without approval",
    match = [
        "gh pr view 123",
        "gh pr checks 123",
        "gh pr diff 123",
        "gh pr list --state open",
        "gh pr status",
    ],
    not_match = [
        "gh pr create --title T --body B",
        "gh pr merge 123",
        "gh pr close 123",
    ],
)

prefix_rule(
    pattern = ["gh", "repo", "view"],
    decision = "allow",
    justification = "Read-only repository metadata inspection is safe to run without approval",
    match = [
        "gh repo view",
        "gh repo view openai/codex",
    ],
    not_match = [
        "gh repo create my-repo --public",
        "gh repo edit my-repo --enable-issues=false",
    ],
)

prefix_rule(
    pattern = ["git", "commit", "-m"],
    decision = "allow",
    justification = "Non-interactive commit with explicit message is a common, bounded operation",
    match = [
        "git commit -m 'chore: update config'",
        "git commit -m 'fix: resolve shell keybinding'",
    ],
    not_match = [
        "git commit --amend -m 'update'",
        "git commit -a -m 'update'",
        "git commit",
    ],
)

prefix_rule(
    pattern = ["git", "add"],
    decision = "allow",
    justification = "Staging explicit file paths is a common, bounded operation",
    match = [
        "git add dotfiles/codex/rules/default.rules",
        "git add zsh/prompt.zsh setup.sh",
    ],
    not_match = [
        "git add .",
        "git add -A",
        "git add --all",
        "git add -u",
    ],
)

prefix_rule(
    pattern = ["git", "push", "--set-upstream", "origin"],
    decision = "allow",
    justification = "Setting upstream to origin for current branch is a common first push operation",
    match = [
        "git push --set-upstream origin feature/iterm-keybindings",
        "git push --set-upstream origin my-branch",
    ],
    not_match = [
        "git push --force",
        "git push --force-with-lease",
        "git push --tags",
    ],
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "allow",
    justification = "Regular push is allowed; force variants are explicitly forbidden by separate rules",
    match = [
        "git push",
        "git push origin my-branch",
    ],
    not_match = [
        "git push --force",
        "git push --force-with-lease",
        "git push -f",
        "git push --tags",
    ],
)

prefix_rule(
    pattern = ["git", ["reset", "checkout", "clean"]],
    decision = "allow",
    justification = "User-approved local working tree operations",
)

prefix_rule(
    pattern = ["git", "push", ["--force", "--force-with-lease", "-f"]],
    decision = "forbidden",
    justification = "Force pushes are explicitly disallowed",
)

prefix_rule(
    pattern = ["git", "push", ["origin", "upstream"], ["--force", "--force-with-lease", "-f"]],
    decision = "forbidden",
    justification = "Force pushes are explicitly disallowed, including remote-qualified pushes",
)

prefix_rule(
    pattern = ["git", "push", ["-u", "--set-upstream"], "origin", ["--force", "--force-with-lease", "-f"]],
    decision = "forbidden",
    justification = "Force pushes are explicitly disallowed, including upstream setup flows",
)

prefix_rule(
    pattern = ["git", ["add", "commit", "merge", "pull", "push", "rebase", "reset", "restore", "switch", "checkout", "clean"]],
    decision = "prompt",
    justification = "Git state-changing commands should always require approval",
)

prefix_rule(
    pattern = ["gh", ["pr", "repo", "issue"], ["create", "edit", "merge", "close", "reopen", "delete"]],
    decision = "prompt",
    justification = "GitHub state-changing commands should always require approval",
)

prefix_rule(
    pattern = ["bash", ["-c", "-lc"]],
    decision = "prompt",
    justification = "Shell wrappers can hide multiple commands and should be reviewed",
)

prefix_rule(
    pattern = ["zsh", ["-c", "-lc"]],
    decision = "prompt",
    justification = "Shell wrappers can hide multiple commands and should be reviewed",
)

prefix_rule(
    pattern = ["sh", "-c"],
    decision = "prompt",
    justification = "Shell wrappers can hide multiple commands and should be reviewed",
)

prefix_rule(
    pattern = ["rm"],
    decision = "forbidden",
    justification = "Direct file deletion is blocked; use git-aware alternatives or manual review",
)
